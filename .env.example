# Plantilla — copiar a .env y rellenar. NUNCA commitear .env.
PORT=3000
DATABASE_URL="file:./prisma/dev.db"   # local SQLite, en Railway viene de Postgres
JWT_SECRET=                            # openssl rand -base64 48
MASTER_DELETE_PASSWORD=                # contraseña maestra del admin

# Google Maps
VITE_GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_API_KEY=

# Google Calendar OAuth (opcional, solo si integras Calendar)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback

# Seed inicial (solo primera instalación)
SEED_ADMIN_PASSWORD=
SEED_AGENT_PASSWORD=
