generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id         Int       @id @default(autoincrement())
  email      String    @unique
  password   String
  name       String
  phone      String?   // Celular del agente — aparece en el mensaje de confirmación al cliente
  role       String    @default("AGENT") // AGENT, ADMIN
  createdAt  DateTime  @default(now())
  lastLat        Float?
  lastLng        Float?
  lastSeenAt     DateTime?
  connectedSince DateTime?
  fcmToken       String?         // legado — reemplazado por UserFcmToken
  visits         Visit[]
  locationLogs   LocationLog[]
  broadcastReads BroadcastRead[]
  fcmTokens      UserFcmToken[]  // M6: soporte multi-dispositivo
  broadcasts     Broadcast[]     // M7: notificaciones dirigidas
  contracts      Contract[]      // C1: contratos diligenciados
}

model UserFcmToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt  // M6: detectar tokens inactivos para limpieza

  @@index([userId])
  @@index([updatedAt])
}

model LocationLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Broadcast {
  id        Int             @id @default(autoincrement())
  title     String
  body      String
  createdAt DateTime        @default(now())
  userId    Int?            // M7: null = masivo (todos), set = personal (solo ese agente)
  user      User?           @relation(fields: [userId], references: [id])
  reads     BroadcastRead[]

  @@index([userId])
}

model BroadcastRead {
  id          Int       @id @default(autoincrement())
  broadcastId Int
  userId      Int
  seenAt      DateTime  @default(now())
  broadcast   Broadcast @relation(fields: [broadcastId], references: [id])
  user        User      @relation(fields: [userId], references: [id])
  @@unique([broadcastId, userId])
  @@index([userId])
}

model Property {
  id        Int      @id @default(autoincrement())
  address   String
  client    String
  lat       Float?
  lng       Float?
  createdAt DateTime @default(now())
  visits    Visit[]
  contracts Contract[] // C1
}

model Visit {
  id               Int       @id @default(autoincrement())
  userId           Int
  propertyId       Int
  scheduledStart   DateTime
  estimatedDuration Int      // In minutes
  status           String    @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, MISSED
  type             String    // SHOWING, APPRAISAL, INSPECTION
  actualStart      DateTime?
  actualEnd        DateTime?
  checkInLat       Float?
  checkInLng       Float?
  checkOutLat      Float?
  checkOutLng      Float?

  notes            String?
  outcome          String?
  clientName       String?
  clientPhone      String?
  clientEmail      String?    // Correo del cliente — invita al evento de Google Calendar
  modality         String    @default("ON_SITE") // ON_SITE (presencial), PHONE (captación por llamada)
  confirmedAt      DateTime?  // Fecha en que el asesor confirmó la cita con el cliente (WhatsApp)
  deletedAt        DateTime?  // A2: Soft delete — null = activa, fecha = eliminada
  googleEventId    String?    // M8: id del evento sincronizado en Google Calendar

  user      User     @relation(fields: [userId], references: [id])
  property  Property @relation(fields: [propertyId], references: [id])
  images    VisitImage[]
  contracts Contract[] // C1

  @@index([userId])
  @@index([propertyId])
  @@index([scheduledStart])
}

// M8: Tokens OAuth para integraciones (single-row: una cuenta corporativa por kind)
model IntegrationToken {
  id           Int      @id @default(autoincrement())
  kind         String   @unique  // "google_calendar"
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  scope        String?
  accountEmail String?
  calendarId   String?  @default("primary")
  updatedAt    DateTime @updatedAt
}

model VisitImage {
  id      Int    @id @default(autoincrement())
  visitId Int
  url     String

  visit Visit @relation(fields: [visitId], references: [id])
}

// C1: Contratos diligenciados por agentes (Administración / Arrendamiento).
// data = JSON serializado con los campos del formulario (SQLite no soporta Json en Prisma 5).
// El PDF no se almacena: se regenera bajo demanda desde data.
model Contract {
  id         Int       @id @default(autoincrement())
  type       String    // ADMINISTRACION, ARRENDAMIENTO
  status     String    @default("DRAFT") // DRAFT, PENDING_APPROVAL, APPROVED, REJECTED, SENT
  data       String    // JSON con los campos del formulario
  userId     Int       // agente que lo diligenció
  visitId    Int?      // visita de origen (pre-llenado), opcional
  propertyId Int?      // inmueble asociado, opcional
  shareToken String?   @unique // token del link público de descarga (fase 2)
  reviewNote String?   // comentario del admin al aprobar/rechazar
  reviewedBy Int?      // id del admin que revisó
  reviewedAt DateTime?
  sentAt     DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id])
  visit    Visit?    @relation(fields: [visitId], references: [id])
  property Property? @relation(fields: [propertyId], references: [id])

  @@index([userId])
  @@index([status])
}
