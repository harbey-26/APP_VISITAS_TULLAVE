generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id         Int       @id @default(autoincrement())
  email      String    @unique
  password   String
  name       String
  role       String    @default("AGENT") // AGENT, ADMIN
  createdAt  DateTime  @default(now())
  lastLat        Float?
  lastLng        Float?
  lastSeenAt     DateTime?
  connectedSince DateTime?
  fcmToken       String?         // legado — reemplazado por UserFcmToken
  visits         Visit[]
  locationLogs   LocationLog[]
  broadcastReads BroadcastRead[]
  fcmTokens      UserFcmToken[]  // M6: soporte multi-dispositivo
}

model UserFcmToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt  // M6: detectar tokens inactivos para limpieza

  @@index([userId])
  @@index([updatedAt])
}

model LocationLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Broadcast {
  id        Int             @id @default(autoincrement())
  title     String
  body      String
  createdAt DateTime        @default(now())
  reads     BroadcastRead[]
}

model BroadcastRead {
  id          Int       @id @default(autoincrement())
  broadcastId Int
  userId      Int
  seenAt      DateTime  @default(now())
  broadcast   Broadcast @relation(fields: [broadcastId], references: [id])
  user        User      @relation(fields: [userId], references: [id])
  @@unique([broadcastId, userId])
  @@index([userId])
}

model Property {
  id        Int      @id @default(autoincrement())
  address   String
  client    String
  lat       Float?
  lng       Float?
  createdAt DateTime @default(now())
  visits    Visit[]
}

model Visit {
  id               Int       @id @default(autoincrement())
  userId           Int
  propertyId       Int
  scheduledStart   DateTime
  estimatedDuration Int      // In minutes
  status           String    @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, MISSED
  type             String    // SHOWING, APPRAISAL, INSPECTION
  actualStart      DateTime?
  actualEnd        DateTime?
  checkInLat       Float?
  checkInLng       Float?
  checkOutLat      Float?
  checkOutLng      Float?

  notes            String?
  outcome          String?
  clientName       String?
  clientPhone      String?
  deletedAt        DateTime?  // A2: Soft delete — null = activa, fecha = eliminada

  user     User     @relation(fields: [userId], references: [id])
  property Property @relation(fields: [propertyId], references: [id])
  images   VisitImage[]

  @@index([userId])
  @@index([propertyId])
  @@index([scheduledStart])
}

model VisitImage {
  id      Int    @id @default(autoincrement())
  visitId Int
  url     String
  
  visit Visit @relation(fields: [visitId], references: [id])
}
